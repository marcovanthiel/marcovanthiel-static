# Cloudflare Pages headers — cache-policies + security
# Docs: https://developers.cloudflare.com/pages/configuration/headers/

# Default: HTML, geen agressieve cache (zodat tekst-updates direct live zijn)
# maar wel security-headers.
/*
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), camera=(), microphone=(), payment=()
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; img-src 'self' data: https://api.kunstcollectie.marcovanthiel.nl https://kunstcollectie.marcovanthiel.nl; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://api.kunstcollectie.marcovanthiel.nl; form-action 'self'
  Cache-Control: public, max-age=300, stale-while-revalidate=86400

# /wimbledon: zelfstandige pagina met één inline <script> (tabs + dblclick);
# de site-brede CSP (script-src 'self') zou die blokkeren. Alleen hier
# versoepelen; de overige security-headers erven van /* hierboven.
/wimbledon/*
  ! Content-Security-Policy
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; img-src 'self' data:; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; connect-src 'self' https://site.api.espn.com https://www.wimbledon.com; form-action 'self'

# /italie2026: eigen scripts/styles (self), maar de Leaflet-kaart laadt
# OpenStreetMap-tiles — alleen hier img-src verruimen.
/italie2026/*
  ! Content-Security-Policy
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; img-src 'self' data: https://tile.openstreetmap.org; script-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self'; connect-src 'self'; form-action 'self'

# Statische assets met fingerprint in de filename — agressief cachen
/css/*
  Cache-Control: public, max-age=31536000, immutable

/js/*
  Cache-Control: public, max-age=31536000, immutable

/images/*
  Cache-Control: public, max-age=2592000

/fonts/*
  Cache-Control: public, max-age=31536000, immutable

/favicon.svg
  Cache-Control: public, max-age=604800

/manifest.webmanifest
  Cache-Control: public, max-age=86400
  Content-Type: application/manifest+json

# Grote galerij-assets (wijzigen niet) — agressief cachen
/felix/*
  Cache-Control: public, max-age=2592000
/biennalevenetie2026/assets/*
  Cache-Control: public, max-age=2592000
